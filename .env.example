# LiveKit Cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# AI providers
# LLM uses LiveKit Cloud Inference by default (same billing as STT/TTS fallbacks).
# Set OPENAI_LLM_DIRECT=true to call OpenAI with OPENAI_API_KEY instead.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_LLM_DIRECT=
LIVEKIT_LLM_MODEL=openai/gpt-4.1-mini
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Twilio / warm transfer
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
SUPERVISOR_PHONE_NUMBER=

# Internal — native local PostgreSQL (port 5432)
DATABASE_URL=postgresql://vaizo:vaizo@localhost:5432/vaizo
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_LIVEKIT_URL=wss://vaizo-e1kvc0cn.livekit.cloud
