{
  "name": "vaizo",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:migrate": "pnpm --filter @vaizo/database db:migrate",
    "db:generate": "pnpm --filter @vaizo/database db:generate",
    "db:push": "pnpm --filter @vaizo/database db:push",
    "db:setup": "pnpm db:generate && pnpm db:push"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.26.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "onnxruntime-node",
      "@livekit/local-inference",
      "@ffmpeg-installer/linux-x64",
      "protobufjs"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
